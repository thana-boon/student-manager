# Student Manager - ตัวอย่าง environment
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง:  cp .env.example .env

# Database หลัก (student_manager)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=student_manager
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Database โรงเรียนเดิม (school_app) สำหรับ academic_year และ student
DB_SCHOOL_HOST=127.0.0.1
DB_SCHOOL_PORT=3306
DB_SCHOOL_NAME=school_app
DB_SCHOOL_USER=root
DB_SCHOOL_PASS=
DB_SCHOOL_CHARSET=utf8mb4

# App
APP_NAME=Student Manager
APP_TIMEZONE=Asia/Bangkok

# School schema overrides
SCHOOL_ACADEMIC_YEARS_TABLE=academic_years
SCHOOL_STUDENTS_TABLE=students
